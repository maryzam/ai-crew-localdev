{
  "schema_version": "2",
  "default_session_ttl": "8h",
  "default_idle_timeout": "1h",
  "agents": {
    "codex": {
      "resources": [
        "github:repo:owner/repo-one",
        "github:repo:owner/repo-two"
      ],
      "providers": {
        "github": {
          "installation_id": 42,
          "default_permissions": {
            "contents": "write",
            "pull_requests": "write",
            "metadata": "read"
          }
        }
      }
    }
  }
}
