#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
zero_sha="0000000000000000000000000000000000000000"
head_sha="$(git rev-parse HEAD 2>/dev/null || true)"

# git feeds "<local_ref> <local_sha> <remote_ref> <remote_sha>" per ref on
# stdin. Capture it once so both checks below iterate over the same input.
refs="$(cat)"

# Mirror the CI "Semantic Quality Gates" inline-comment check, but only for the
# branch commit actually being pushed when it matches the working tree. Tag
# pushes and deletions carry no Go diff to gate; pushing a branch other than the
# checkout would read an unrelated working tree, so leave those to CI.
inline_failed=0
while read -r _local_ref local_sha remote_ref _remote_sha; do
	case "${remote_ref:-}" in
		refs/heads/*) ;;
		*) continue ;;
	esac
	if [ "$local_sha" = "$zero_sha" ] || [ "$local_sha" != "$head_sha" ]; then
		continue
	fi

	echo "pre-push: checking inline comments in changed Go files..." >&2
	if ! "$ROOT/scripts/check-inline-comments.sh" "" "$local_sha"; then
		inline_failed=1
	fi
done <<EOF
$refs
EOF

if [ "$inline_failed" -ne 0 ]; then
	exit 1
fi

current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
if [ -z "$current_branch" ]; then
	printf '%s\n' 'pre-push: detached HEAD; skipping branch tracking check' >&2
	exit 0
fi

expected_remote_ref=$(git config --get "branch.${current_branch}.merge" || true)
if [ -z "$expected_remote_ref" ]; then
	printf 'pre-push: branch.%s.merge is not configured; set an upstream before pushing\n' "$current_branch" >&2
	exit 1
fi

checked=0
failed=0

while read -r local_ref _local_sha remote_ref _remote_sha; do
	if [ -z "${local_ref:-}" ]; then
		continue
	fi

	case "$remote_ref" in
		refs/heads/*) ;;
		*) continue ;;
	esac

	if [ "$local_ref" != "refs/heads/${current_branch}" ] && [ "$local_ref" != "HEAD" ]; then
		continue
	fi

	checked=1
	if [ "$expected_remote_ref" != "$remote_ref" ]; then
		printf 'pre-push: branch.%s.merge is %s, but push target is %s\n' "$current_branch" "$expected_remote_ref" "$remote_ref" >&2
		failed=1
	fi
done <<EOF
$refs
EOF

if [ "$checked" -eq 0 ]; then
	printf 'pre-push: no current branch update found; skipping branch tracking check\n' >&2
	exit 0
fi

exit "$failed"
