#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

# Mirror the CI "Semantic Quality Gates" inline-comment check so violations are
# caught before they reach CI, not after.
echo "pre-push: checking inline comments in changed Go files..." >&2
"$ROOT/scripts/check-inline-comments.sh"

current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
if [ -z "$current_branch" ]; then
	printf '%s\n' 'pre-push: detached HEAD; skipping branch tracking check' >&2
	exit 0
fi

expected_remote_ref=$(git config --get "branch.${current_branch}.merge" || true)
if [ -z "$expected_remote_ref" ]; then
	printf 'pre-push: branch.%s.merge is not configured; set an upstream before pushing\n' "$current_branch" >&2
	exit 1
fi

checked=0
failed=0

while read -r local_ref _local_sha remote_ref _remote_sha; do
	if [ -z "${local_ref:-}" ]; then
		continue
	fi

	case "$remote_ref" in
		refs/heads/*) ;;
		*) continue ;;
	esac

	if [ "$local_ref" != "refs/heads/${current_branch}" ] && [ "$local_ref" != "HEAD" ]; then
		continue
	fi

	checked=1
	if [ "$expected_remote_ref" != "$remote_ref" ]; then
		printf 'pre-push: branch.%s.merge is %s, but push target is %s\n' "$current_branch" "$expected_remote_ref" "$remote_ref" >&2
		failed=1
	fi
done

if [ "$checked" -eq 0 ]; then
	printf 'pre-push: no current branch update found; skipping branch tracking check\n' >&2
	exit 0
fi

exit "$failed"
