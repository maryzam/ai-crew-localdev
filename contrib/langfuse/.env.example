# Langfuse v3 configuration
# Copy to .env and fill in values before running docker compose up.

# Database
DATABASE_URL=postgresql://langfuse:langfuse-dev@postgres:5432/langfuse

# ClickHouse
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_MIGRATION_URL=clickhouse://clickhouse:9000

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# S3-compatible storage (MinIO)
LANGFUSE_S3_BUCKET_NAME=langfuse
LANGFUSE_S3_ENDPOINT=http://minio:9000
LANGFUSE_S3_ACCESS_KEY=minioadmin
LANGFUSE_S3_SECRET_KEY=minioadmin
LANGFUSE_S3_REGION=us-east-1
LANGFUSE_S3_FORCE_PATH_STYLE=true

# Langfuse secrets — CHANGE ALL THREE before production use
NEXTAUTH_SECRET=change-me-nextauth-secret
SALT=change-me-salt-value
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# Langfuse URL (where the web UI is accessible)
NEXTAUTH_URL=http://localhost:3000

# Postgres password (must match postgres service)
LANGFUSE_POSTGRES_PASSWORD=langfuse-dev

# Headless local project initialization. The compose stack binds its web UI to
# loopback; replace these values before changing that boundary. ai-agent up
# --langfuse exposes only the project keys to the devcontainer shell and scrubs
# them before launching an agent process.
LANGFUSE_INIT_ORG_ID=ai-agent-local
LANGFUSE_INIT_ORG_NAME=AI Agent Local
LANGFUSE_INIT_PROJECT_ID=managed-runs
LANGFUSE_INIT_PROJECT_NAME=Managed Runs
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-ai-agent-local
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-ai-agent-local-change-me
LANGFUSE_INIT_USER_EMAIL=local@ai-agent.invalid
LANGFUSE_INIT_USER_NAME=Local Operator
LANGFUSE_INIT_USER_PASSWORD=change-me-local-only
