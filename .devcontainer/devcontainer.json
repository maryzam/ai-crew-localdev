{
  "name": "ai-agent-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "initializeCommand": "mkdir -p ${localEnv:XDG_RUNTIME_DIR}/ai-agent",

  // Podman rootless: map host UID/GID into the container.
  // Runtime hardening: drop all capabilities, prevent privilege escalation,
  // read-only root filesystem with tmpfs for writable scratch areas.
  "runArgs": [
    "--userns=keep-id",
    "--cap-drop=ALL",
    "--security-opt=no-new-privileges",
    "--read-only",
    "--tmpfs=/tmp:rw,noexec,nosuid,size=512m",
    // Ephemeral home — shell history and dotfiles reset on restart (by design).
    // To persist specific configs, add a named volume mount below.
    "--tmpfs=/home/dev:rw,nosuid,size=1g"
  ],
  "remoteUser": "dev",
  "updateRemoteUserUID": false,

  // Mount the user's repos directory as the workspace.
  // Start the devcontainer first, shell in, and run `ai-agent run` inside it.
  // Set AI_AGENT_WORKSPACE on the host before launching:
  //   export AI_AGENT_WORKSPACE="$HOME/github"
  "workspaceMount": "source=${localEnv:AI_AGENT_WORKSPACE},target=/workspace,type=bind",
  "workspaceFolder": "/workspace",

  "mounts": [
    // Mount the ai-agent runtime directory so the expected broker socket path
    // exists inside the container namespace. entrypoint.sh still fails fast
    // unless /run/ai-agent/broker.sock resolves to a writable Unix socket.
    "source=${localEnv:XDG_RUNTIME_DIR}/ai-agent,target=/run/ai-agent,type=bind"
  ],

  "containerEnv": {
    "AI_AGENT_AUTH_SOCK": "/run/ai-agent/broker.sock",
    "AI_AGENT_REAL_GH": "/usr/bin/gh"
  }
}
